export POSTGRES_HOST=localhost
export POSTGRES_PORT=5432
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=secret

# GitHub token for the github integration (integrations.github.token).
# LOCALLY this is how the create-tenant-chart scaffolder authenticates: it
# falls back to this integration token when no per-user OAuth token is present.
# Use your gh CLI token:
#   export GITHUB_TOKEN=$(gh auth token)
export GITHUB_TOKEN=

# GitHub OAuth app credentials for the auth.providers.github provider.
# PROD/STAGE ONLY: enables per-user PR authorship in the scaffolder
# (RepoUrlPicker requestUserCredentials mints secrets.USER_OAUTH_TOKEN, so PRs
# are authored by the initiator rather than the integration identity).
# Leave unset locally — the github provider is disabled in development and the
# scaffolder falls back to GITHUB_TOKEN above. If the auth.providers.github
# block ships to a non-dev environment, these MUST be provisioned there or the
# auth backend fails to start (NODE_ENV != development re-throws).
export AUTH_GITHUB_CLIENT_ID=
export AUTH_GITHUB_CLIENT_SECRET=