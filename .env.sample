export POSTGRES_HOST=localhost
export POSTGRES_PORT=5432
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=secret

# GitHub OAuth app credentials for the auth.providers.github provider.
# Used by the create-tenant-chart scaffolder to mint a per-user token
# (RepoUrlPicker requestUserCredentials) so PRs are authored by the initiator.
# Optional locally — if unset, the github provider is disabled in development
# and the scaffolder's PR steps simply won't have a token. REQUIRED in any
# non-dev environment: the auth backend hard-fails to start if this provider
# block is present without these secrets when NODE_ENV != development.
export AUTH_GITHUB_CLIENT_ID=
export AUTH_GITHUB_CLIENT_SECRET=